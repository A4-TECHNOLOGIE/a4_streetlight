{"entries":[{"timestamp":1782381309741,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":4539,"diffs":[[1,"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":337,"diffs":[[1,"\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":119,"length1":86,"diffs":[[1,"        \"microphone\": \"*\"\n"]]},{"start1":209,"length1":45,"diffs":[[1,"        \"README.md\"\n"]]},{"start1":236,"length1":35,"diffs":[[1,"    \"additionalFilePaths\": []\n"]]}]},{"type":"added","filename":"lampadaire.ts","value":"//% color=\"#f2a900\" icon=\"\\uf0eb\" block=\"A4 Lampadaire\"\nnamespace a4_lampadaire {\n    let strip: neopixel.Strip = null\n    let power = 50\n\n    export enum LampadaireColor {\n        //% block=\"Zone nature 1800 K\"\n        Nature,\n        //% block=\"Parc 2200 K\"\n        Park,\n        //% block=\"Résidence 2700 K\"\n        Residence,\n        //% block=\"Urbain 3000 K\"\n        Urban,\n        //% block=\"Passage piéton 6500 K\"\n        Pedestrian\n    }\n\n    function initStrip(): void {\n        if (strip == null) {\n            strip = neopixel.create(DigitalPin.P0, 10, NeoPixelMode.RGB)\n            strip.setBrightness(power)\n            strip.clear()\n            strip.show()\n        }\n    }\n\n    //% block=\"pedestrian detected\"\n    //% group=\"Sensors\"\n    export function pedestrianDetected(): boolean {\n        return pins.digitalReadPin(DigitalPin.P1) == 1\n    }\n\n    //% block=\"low brightness\"\n    //% group=\"Sensors\"\n    export function lowBrightness(): boolean {\n        return input.lightLevel() < 50\n    }\n\n    //% block=\"streetlight power %value \\\\%\"\n    //% value.min=0 value.max=100\n    //% group=\"Streetlight\"\n    export function streetlightPower(value: number): void {\n        initStrip()\n        value = Math.constrain(value, 0, 100)\n        power = Math.map(value, 0, 100, 0, 255)\n        strip.setBrightness(power)\n        strip.show()\n    }\n\n    //% block=\"turn on streetlight R %red G %green B %blue\"\n    //% red.min=0 red.max=255\n    //% green.min=0 green.max=255\n    //% blue.min=0 blue.max=255\n    //% group=\"Streetlight\"\n    export function turnOnRGB(red: number, green: number, blue: number): void {\n        initStrip()\n        strip.showColor(neopixel.rgb(\n            Math.constrain(red, 0, 255),\n            Math.constrain(green, 0, 255),\n            Math.constrain(blue, 0, 255)\n        ))\n    }\n\n    //% block=\"turn on streetlight %color\"\n    //% group=\"Streetlight\"\n    export function turnOnStreetlight(color: LampadaireColor): void {\n        initStrip()\n\n        if (color == LampadaireColor.Nature) {\n            strip.showColor(neopixel.rgb(255, 125, 0))\n        } else if (color == LampadaireColor.Park) {\n            strip.showColor(neopixel.rgb(255, 147, 41))\n        } else if (color == LampadaireColor.Residence) {\n            strip.showColor(neopixel.rgb(255, 169, 87))\n        } else if (color == LampadaireColor.Urban) {\n            strip.showColor(neopixel.rgb(255, 180, 107))\n        } else if (color == LampadaireColor.Pedestrian) {\n            strip.showColor(neopixel.rgb(230, 235, 255))\n        }\n    }\n\n    //% block=\"turn off streetlight\"\n    //% group=\"Streetlight\"\n    export function turnOffStreetlight(): void {\n        initStrip()\n        strip.clear()\n        strip.show()\n    }\n}"}]},{"timestamp":1782386430745,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":4537,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"a4_lampadaire_streetlightPower\" disabled-reasons=\"pxt_automatic_disabled\" x=\"398\" y=\"-209\"><value name=\"value\"><shadow type=\"math_number_minmax\" 