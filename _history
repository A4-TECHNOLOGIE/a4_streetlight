></value></block><block type=\"device_forever\" x=\"149\" y=\"145\"><statement name=\"HANDLER\"><block type=\"a4_lampadaire_streetlightPower\"><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"100\" label=\"Value\" precision=\"0\"></mutation><field name=\"SLIDER\">100</field></shadow></value><next><block type=\"a4_lampadaire_turnOnStreetlight\"><field name=\"color\">a4_lampadaire.LampadaireColor.Nature</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_lampadaire_turnOnStreetlight\"><field name=\"color\">a4_lampadaire.LampadaireColor.Pedestrian</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_lampadaire_turnOnStreetlight\"><field name=\"color\">a4_lampadaire.LampadaireColor.Urban</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_lampadaire_streetlightPower\"><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"100\" label=\"Value\" precision=\"0\"></mutation><field name=\"SLIDER\">40</field></shadow></value><next><block type=\"a4_lampadaire_turnOnStreetlight\"><field name=\"color\">a4_lampadaire.LampadaireColor.Nature</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_lampadaire_turnOnStreetlight\"><field name=\"color\">a4_lampadaire.LampadaireColor.Pedestrian</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value><next><block type=\"a4_lampadaire_turnOnStreetlight\"><field name=\"color\">a4_lampadaire.LampadaireColor.Urban</field><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">2000</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"","README.md":"","lampadaire.ts":"//% color=\"#f2a900\" icon=\"\\uf0eb\" block=\"A4 Lampadaire\"\nnamespace a4_lampadaire {\n    let strip: neopixel.Strip = null\n    let power = 50\n\n    export enum LampadaireColor {\n        //% block=\"Zone nature 1800 K\"\n        Nature,\n        //% block=\"Parc 2200 K\"\n        Park,\n        //% block=\"Résidence 2700 K\"\n        Residence,\n        //% block=\"Urbain 3000 K\"\n        Urban,\n        //% block=\"Passage piéton 6500 K\"\n        Pedestrian\n    }\n\n    function initStrip(): void {\n        if (strip == null) {\n            strip = neopixel.create(DigitalPin.P0, 10, NeoPixelMode.RGB)\n            strip.setBrightness(power)\n            strip.clear()\n            strip.show()\n        }\n    }\n\n    //% block=\"pedestrian detected\"\n    //% group=\"Sensors\"\n    export function pedestrianDetected(): boolean {\n        return pins.digitalReadPin(DigitalPin.P1) == 1\n    }\n\n    //% block=\"low brightness\"\n    //% group=\"Sensors\"\n    export function lowBrightness(): boolean {\n        return input.lightLevel() < 50\n    }\n\n    //% block=\"streetlight power %value \\\\%\"\n    //% value.min=0 value.max=100\n    //% group=\"Streetlight\"\n    export function streetlightPower(value: number): void {\n        initStrip()\n        value = Math.constrain(value, 0, 100)\n        power = Math.map(value, 0, 100, 0, 255)\n        strip.setBrightness(power)\n        strip.show()\n    }\n\n    //% block=\"turn on streetlight R %red G %green B %blue\"\n    //% red.min=0 red.max=255\n    //% green.min=0 green.max=255\n    //% blue.min=0 blue.max=255\n    //% group=\"Streetlight\"\n    export function turnOnRGB(red: number, green: number, blue: number): void {\n        initStrip()\n        strip.showColor(neopixel.rgb(\n            Math.constrain(red, 0, 255),\n            Math.constrain(green, 0, 255),\n            Math.constrain(blue, 0, 255)\n        ))\n    }\n\n    //% block=\"turn on streetlight %color\"\n    //% group=\"Streetlight\"\n    export function turnOnStreetlight(color: LampadaireColor): void {\n        initStrip()\n\n        if (color == LampadaireColor.Nature) {\n            strip.showColor(neopixel.rgb(255, 125, 0))\n        } else if (color == LampadaireColor.Park) {\n            strip.showColor(neopixel.rgb(255, 147, 41))\n        } else if (color == LampadaireColor.Residence) {\n            strip.showColor(neopixel.rgb(255, 169, 87))\n        } else if (color == LampadaireColor.Urban) {\n            strip.showColor(neopixel.rgb(255, 180, 107))\n        } else if (color == LampadaireColor.Pedestrian) {\n            strip.showColor(neopixel.rgb(230, 235, 255))\n        }\n    }\n\n    //% block=\"turn off streetlight\"\n    //% group=\"Streetlight\"\n    export function turnOffStreetlight(): void {\n        initStrip()\n        strip.clear()\n        strip.show()\n    }\n}","pxt.json":"{\n    \"name\": \"a4 lampadaire\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"neopixel\": \"github:microsoft/pxt-neopixel#v0.7.6\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"lampadaire.ts\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1782389172235,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"a4_lampadaire_streetlightPower\" disabled-reasons=\"pxt_automatic_disabled\" x=\"398\" y=\"-209\"><value name=\"value\"><shadow type=\"math_number_minmax\" disabled-reasons